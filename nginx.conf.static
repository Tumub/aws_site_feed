server {
    listen 80;
    listen [::]:80;
    server_name torquefoundryadvisory.com www.torquefoundryadvisory.com;

    root /var/www/torquefoundry;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # Optional: Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|webp)$ {
        expires 1y;
        add_header Cache-Control "public, no-transform";
    }
}
